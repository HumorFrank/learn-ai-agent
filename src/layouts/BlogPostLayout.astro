---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  date: Date;
  tags?: string[];
}

const { title, date, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout pageTitle={title}>
  <article class="post animate-in">
    <!-- Post header -->
    <header class="post-header">
      <a href={`${base}/blog`} class="back-link">&larr; 返回文章列表</a>

      <h1 class="post-title">{title}</h1>

      <div class="post-meta">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => (
              <a href={`${base}/tags/${tag}`} class="tag-pill">#{tag}</a>
            ))}
          </div>
        )}
      </div>

      <div class="post-divider"></div>
    </header>

    <!-- Post content -->
    <div class="post-body">
      <slot />
    </div>

    <!-- Post footer -->
    <footer class="post-footer">
      <div class="post-divider"></div>
      <a href={`${base}/blog`} class="back-link">&larr; 返回文章列表</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 3rem auto;
  }

  /* ── Header ── */
  .post-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: none;
    padding: 0.35rem 0.75rem;
    border-radius: var(--radius-sm);
    transition: all 0.2s var(--ease-smooth);
  }

  .back-link:hover {
    color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 1.5rem 0 1rem;
    letter-spacing: -0.035em;
    line-height: 1.2;
    background: linear-gradient(135deg, var(--color-text) 60%, var(--color-accent));
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-variant-numeric: tabular-nums;
  }

  .post-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-display);
    transition: all 0.2s;
    border: 1px solid transparent;
  }

  .tag-pill:hover {
    border-color: var(--color-border-accent);
    background: var(--glow-tag-hover);
    color: var(--color-accent-glow);
  }

  .post-divider {
    height: 1px;
    background: linear-gradient(to right, var(--color-border-accent), transparent);
    margin: 1.5rem 0;
  }

  /* ── Body ── */
  .post-body {
    line-height: 1.85;
    font-size: 1rem;
  }

  .post-body :global(h1) {
    font-size: 2rem;
    margin: 2.5rem 0 1rem;
  }

  .post-body :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-body :global(h3) {
    font-size: 1.2rem;
    margin: 1.5rem 0 0.5rem;
  }

  .post-body :global(p) {
    margin: 0 0 1.25rem;
  }

  .post-body :global(blockquote p) {
    margin: 0;
  }
  .post-body :global(blockquote p + p) {
    margin-top: 0.75rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .post-body :global(li) {
    margin: 0.25rem 0;
  }

  .post-body :global(li)::marker {
    color: var(--color-accent);
  }

  .post-body :global(img) {
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-md);
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration-line: underline;
    text-decoration-style: dotted;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-border-accent);
    transition: all 0.2s;
  }

  .post-body :global(a):hover {
    text-decoration-style: solid;
    text-decoration-color: var(--color-accent);
  }

  /* ── Footer ── */
  .post-footer {
    margin-top: 3rem;
  }

  .post-footer .post-divider {
    background: linear-gradient(to right, transparent, var(--color-border-strong), transparent);
    margin-bottom: 1rem;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .post {
      margin: 2rem auto;
    }

    .post-title {
      font-size: 1.85rem;
    }
  }
</style>