---
import BaseLayout from './BaseLayout.astro';

interface Heading {
  text: string;
  slug: string;
  depth: number;
}

export interface Props {
  title: string;
  date: Date;
  tags?: string[];
  headings?: Heading[];
}

const {
  title,
  date,
  tags = [],
  headings = [],
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const formattedDate = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const showToc = headings.length >= 2;
---

<BaseLayout pageTitle={title}>
  <div class="article-container">
    <!-- Main content -->
    <article class="post animate-in">
      <header class="post-header">
        <a href={`${base}/blog`} class="back-link">&larr; 文章列表</a>
        <h1 class="post-title">{title}</h1>

        <div class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map((tag) => (
                <a href={`${base}/tags/${tag}`} class="tag-pill">#{tag}</a>
              ))}
            </div>
          )}
        </div>
      </header>

      <div class="post-body">
        <slot />
      </div>

      <footer class="post-footer">
        <nav class="post-footer-nav">
          <a href={`${base}/blog`} class="back-link">&larr; 文章列表</a>
        </nav>
      </footer>
    </article>

    <!-- Right sidebar: on-page TOC -->
    {showToc && (
      <aside class="right-sidebar">
        <nav class="toc">
          <span class="toc-label">目录</span>
          <ul class="toc-list">
            {headings.map((h) => (
              <li class:list={['toc-item', { sub: h.depth === 3 }]}>
                <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>
</BaseLayout>

<script>
  function initToc() {
    const tocList = document.querySelector('.toc-list');
    if (!tocList) return;

    const links = [...tocList.querySelectorAll('.toc-link')] as HTMLAnchorElement[];
    if (links.length === 0) return;

    const slugs = links.map((l) => l.getAttribute('href')!.replace('#', ''));

    const postHeadings = document.querySelectorAll('.post-body h2, .post-body h3');
    postHeadings.forEach((h) => {
      const raw = h.textContent?.replace(/[`*_~\[\]()]/g, '').trim() || '';
      const slug = raw
        .toLowerCase()
        .replace(/[^\w一-鿿\s-]/g, '')
        .replace(/\s+/g, '-')
        .replace(/-+/g, '-')
        .replace(/^-|-$/g, '');
      if (slugs.includes(slug) && !h.id) {
        h.id = slug;
      }
    });

    const NAV_OFFSET = 90;
    let ticking = false;

    function updateActive() {
      let activeIndex = -1;
      const headingEls = slugs
        .map((s) => document.getElementById(s))
        .filter(Boolean) as HTMLElement[];

      for (let i = headingEls.length - 1; i >= 0; i--) {
        if (headingEls[i].getBoundingClientRect().top < NAV_OFFSET) {
          activeIndex = i;
          break;
        }
      }

      links.forEach((link, i) => {
        link.classList.toggle('active', i === activeIndex);
      });
    }

    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          updateActive();
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    tocList.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('.toc-link');
      if (!link) return;
      e.preventDefault();
      const id = (link as HTMLAnchorElement).getAttribute('href')!.replace('#', '');
      const target = document.getElementById(id);
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
        links.forEach((l) => l.classList.remove('active'));
        (link as HTMLElement).classList.add('active');
        history.replaceState(null, '', `#${id}`);
      }
    });

    updateActive();
  }

  initToc();
</script>

<style>
  /* ── Two-Column Layout ── */
  .article-container {
    display: grid;
    grid-template-columns: minmax(0, 680px) 200px;
    gap: 3rem;
    justify-content: center;
    margin: 4rem 0;
  }

  .post {
    min-width: 0;
  }

  /* ── Post Header ── */
  .post-header {
    margin-bottom: 3rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-text-dim);
    background: none;
    padding: 0;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--color-text);
    background: none;
  }

  .post-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin: 2rem 0 1.25rem;
    letter-spacing: -0.04em;
    line-height: 1.15;
    color: var(--color-text);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .post-meta time {
    color: var(--color-text-dim);
    font-size: 0.85rem;
    font-variant-numeric: tabular-nums;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag-pill {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    background: none;
    color: var(--color-text-dim);
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 500;
    font-family: var(--font-display);
    transition: color 0.2s ease;
    border: none;
  }

  .tag-pill:hover {
    color: var(--color-text);
    background: none;
  }

  /* ── Post Body ── */
  .post-body {
    line-height: 1.85;
    font-size: 1rem;
    color: var(--color-text);
  }

  .post-body :global(h1) {
    font-size: 2rem;
    font-weight: 700;
    margin: 3rem 0 1rem;
    letter-spacing: -0.03em;
  }

  .post-body :global(h2) {
    font-size: 1.4rem;
    font-weight: 600;
    margin: 2.75rem 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .post-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 1.75rem 0 0.5rem;
  }

  .post-body :global(p) {
    margin: 0 0 1.25rem;
  }

  .post-body :global(blockquote p) {
    margin: 0;
  }
  .post-body :global(blockquote p + p) {
    margin-top: 0.75rem;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .post-body :global(li) {
    margin: 0.25rem 0;
  }

  .post-body :global(li)::marker {
    color: var(--color-text-dim);
  }

  .post-body :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    transition: color 0.2s ease;
  }

  .post-body :global(a):hover {
    color: var(--color-accent-glow);
  }

  /* ── Post Footer ── */
  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  /* ── Right Sidebar TOC ── */
  .right-sidebar {
    position: sticky;
    top: calc(var(--nav-height) + 3rem);
    align-self: start;
    max-height: calc(100vh - var(--nav-height) - 6rem);
    overflow-y: auto;
  }

  .toc {
    padding: 0;
  }

  .toc-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-text-dim);
    margin-bottom: 1rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-item {
    margin: 0;
  }

  .toc-link {
    display: block;
    padding: 0.28rem 0;
    font-size: 0.8rem;
    line-height: 1.45;
    color: var(--color-text-dim);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .toc-link:hover {
    color: var(--color-text);
  }

  .toc-link.active {
    color: var(--color-text);
    font-weight: 600;
  }

  .toc-item.sub .toc-link {
    padding-left: 0.85rem;
    font-size: 0.77rem;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .article-container {
      grid-template-columns: minmax(0, 1fr);
      margin: 2.5rem 0;
    }

    .right-sidebar {
      display: none;
    }

    .post-title {
      font-size: 1.85rem;
    }
  }
</style>
