---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="关于我" description="关于我和这个博客">
  <article class="about animate-in">
    <header class="page-header">
      <div class="section-label">
        <span class="label-dot"></span>
        关于
      </div>
      <h1 class="page-title">关于我</h1>
    </header>

    <div class="about-content">
      <div class="about-intro">
        <p class="about-greeting">Hi，我是 AI Agent 小白。</p>
        <p>这个博客记录了我的 AI Agent 学习过程 —— 从零开始，一步步探索和成长。</p>
        <p>这里会分享我在学习过程中的思考、笔记和心得。如果你也在学习类似的技能，希望这些内容能对你有所启发。</p>
      </div>

      <div class="about-divider"></div>

      <div class="about-section">
        <h2>关于这个博客</h2>
        <p>使用 <a href="https://astro.build">Astro</a> 构建，追求简洁、快速的阅读体验。</p>
        <p>专注于内容本身，减少不必要的干扰。每一篇文章都是学习路上的真实记录。</p>
      </div>

      <div class="about-divider"></div>

      <div class="about-section">
        <h2>技术栈</h2>
        <div class="tech-stack">
          <span class="tech-item">Astro</span>
          <span class="tech-item">Markdown</span>
          <span class="tech-item">CSS Variables</span>
          <span class="tech-item">Shiki</span>
          <span class="tech-item">pnpm</span>
          <span class="tech-item">GitHub Pages</span>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .about {
    margin-top: 2rem;
    max-width: var(--max-width);
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--glow-dot);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
  }

  .about-content {
    font-size: 1rem;
    line-height: 1.85;
  }

  .about-greeting {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .about-divider {
    height: 1px;
    background: linear-gradient(to right, var(--color-border-accent), transparent);
    margin: 2rem 0;
  }

  .about-section h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tech-item {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: var(--color-surface);
    color: var(--color-accent);
    border: 1px solid var(--color-border-accent);
    border-radius: var(--radius-sm);
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    transition: all 0.2s var(--ease-smooth);
  }

  .tech-item:hover {
    background: var(--color-accent-soft);
    box-shadow: 0 0 12px var(--glow-tech);
  }
</style>