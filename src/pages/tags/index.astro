---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('blog');
const allTags = [...new Set(posts.flatMap((p) => p.data.tags))];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tagCounts = new Map<string, number>();
posts.forEach((post) => {
  post.data.tags.forEach((tag: string) => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const sortedTags = allTags.sort((a, b) => (tagCounts.get(b) || 0) - (tagCounts.get(a) || 0));
---

<BaseLayout pageTitle="标签" description="按标签浏览文章">
  <section class="tags-page animate-in">
    <header class="page-header">
      <div class="section-label">
        <span class="label-dot"></span>
        标签
      </div>
      <h1 class="page-title">标签</h1>
      <p class="page-count">{allTags.length} 个标签</p>
    </header>

    {allTags.length === 0 ? (
      <div class="empty-state">
        <p>还没有标签。</p>
      </div>
    ) : (
      <div class="tag-cloud stagger">
        {sortedTags.map((tag) => (
          <a href={`${base}/tags/${tag}`} class="tag-card">
            <span class="tag-hash">#</span>
            <span class="tag-name">{tag}</span>
            <span class="tag-count">{tagCounts.get(tag)}</span>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .tags-page {
    margin-top: 2rem;
  }

  .page-header {
    margin-bottom: 2rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }

  .label-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--glow-dot);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .page-count {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .tag-card {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background-image: none;
    transition: all 0.25s var(--ease-smooth);
    box-shadow: var(--shadow-sm);
  }

  .tag-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
    border-color: var(--color-border-accent);
    background: var(--color-surface-hover);
  }

  .tag-hash {
    color: var(--color-accent);
    font-weight: 700;
    font-size: 0.85rem;
    opacity: 0.6;
  }

  .tag-name {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.9rem;
  }

  .tag-card:hover .tag-name {
    color: var(--color-accent);
  }

  .tag-count {
    font-size: 0.72rem;
    color: var(--color-text-dim);
    background: var(--color-bg-alt);
    padding: 0.1rem 0.45rem;
    border-radius: 100px;
    font-weight: 600;
    font-family: var(--font-display);
  }

  .empty-state {
    padding: 4rem 0;
    text-align: center;
    color: var(--color-text-muted);
  }
</style>